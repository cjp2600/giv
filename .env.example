# Copy to .env and fill in (never commit .env)
#
# Fine-grained PAT: GitHub → Settings → Developer settings → Fine-grained tokens
# → add repository "cjp2600/giv" → Contents: Read and write (and Metadata read).
# If push returns 403 "denied to cjp2600", the token lacks access to this repo or SSO is not authorized.
#
# Classic PAT: repo scope is enough.

GITHUB_TOKEN=ghp_your_token_here

# Optional: override release tag version (default 1.0.0 → tag v1.0.0)
# GIV_VERSION=1.0.0
